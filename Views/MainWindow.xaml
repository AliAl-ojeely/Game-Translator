<Window x:Class="GameTranslator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Translator 1.5" Height="700" Width="1150"
        Background="#000000" Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#222222"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#000000"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#1A1A1A"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#004A85"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBarThumb" TargetType="Thumb">
            <Setter Property="MinHeight" Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" 
                                Background="#4A4A4A" 
                                CornerRadius="7" 
                                Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#666666"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="9"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterFallback" />
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0A0A0A" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#1A1A1A" BorderThickness="1">
            <StackPanel Orientation="Horizontal">

                <Button Content="Open Game File" Width="120" Command="{Binding OpenFileCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,15,0"/>

                <TextBlock Text="From" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#888888" FontWeight="SemiBold"/>
                <ComboBox Width="90" SelectedValue="{Binding SelectedSourceLanguage}" SelectedValuePath="Content">
                    <ComboBoxItem Content="English"/>
                    <ComboBoxItem Content="Russian"/>
                    <ComboBoxItem Content="Japanese"/>
                </ComboBox>

                <TextBlock Text="To" VerticalAlignment="Center" Margin="15,0,8,0" Foreground="#888888" FontWeight="SemiBold"/>
                <ComboBox Width="90" SelectedValue="{Binding SelectedTargetLanguage}" SelectedValuePath="Content">
                    <ComboBoxItem Content="Arabic"/>
                    <ComboBoxItem Content="English"/>
                </ComboBox>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="15,0" Background="#333333"/>

                <Grid>
                    <Button Content="Translate All" Width="110" Command="{Binding StartTranslationCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTranslating}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Cancel Translation" Width="125" Command="{Binding CancelTranslationCommand}" Background="#8B0000">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTranslating}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#A93226"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <Button Content="Settings" Width="80" Margin="10,0,0,0" Click="BtnSettings_Click" Style="{StaticResource SecondaryButton}"/>

                <Button Content="Save File" Width="90" Margin="15,0,0,0" 
                        Click="BtnSaveTranslation_Click"
                        Background="#28A745" Foreground="White" BorderThickness="0"
                        Visibility="{Binding IsTranslationFinished, Converter={StaticResource BooleanToVisibilityConverterFallback}}"/>

                <Button Content="Report" Width="80" Margin="10,0,0,0" 
                        Click="BtnReport_Click"
                        Background="#6C757D" Foreground="White" BorderThickness="0"
                        Visibility="{Binding IsTranslationFinished, Converter={StaticResource BooleanToVisibilityConverterFallback}}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#0A0A0A" CornerRadius="5" Padding="10" Margin="0,0,0,10" BorderBrush="#1A1A1A" BorderThickness="1"
                Visibility="{Binding IsTranslating, Converter={StaticResource BooleanToVisibilityConverterFallback}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0" Height="10" Value="{Binding ProgressPercentage}" Minimum="0" Maximum="100" Background="#1E1E1E" Foreground="#0078D7" BorderThickness="0"/>
                <TextBlock Grid.Column="1" Text="{Binding EstimatedTimeRemaining}" Foreground="#888888" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" CornerRadius="8" BorderBrush="#1A1A1A" BorderThickness="1" ClipToBounds="True">
            <DataGrid AutoGenerateColumns="False" 
                      ItemsSource="{Binding TranslationItems}"
                      Background="#000000" AlternatingRowBackground="#050505"
                      HeadersVisibility="Column" GridLinesVisibility="None"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N" Binding="{Binding LineNumber}" Width="50" IsReadOnly="True" Foreground="#888888" FontWeight="SemiBold"/>

                    <DataGridTextColumn Header="Group ID" Binding="{Binding ParentId}" Width="160" IsReadOnly="True" Foreground="#888888"/>
                    <DataGridTextColumn Header="String ID" Binding="{Binding Id}" Width="120" IsReadOnly="True" FontWeight="SemiBold"/>

                    <DataGridTextColumn Header="Original Text" Binding="{Binding OriginalText}" Width="3*" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Translation" Binding="{Binding TranslatedText, UpdateSourceTrigger=PropertyChanged}" Width="4*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TranslatedText}" Value="">
                                        <Setter Property="Foreground" Value="#666666"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>