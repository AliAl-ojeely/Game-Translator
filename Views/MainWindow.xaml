<Window x:Class="GameTranslator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Translator 1.8" Height="700" Width="1150"
        Background="#000000" Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#222222"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#000000"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#1A1A1A"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#004A85"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#111111"/>
                </Trigger>
                <!-- Highlight row in red if an error occurred during translation -->
                <DataTrigger Binding="{Binding IsError}" Value="True">
                    <Setter Property="Background" Value="#8B0000"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverterFallback" />

        <Style x:Key="ModernScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="#4A4A4A" CornerRadius="5" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#666666"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" Background="{TemplateBinding Background}">
                            <Border CornerRadius="7" Background="#121212" Margin="1"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="14"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid x:Name="Bg" Background="{TemplateBinding Background}">
                                    <Border CornerRadius="7" Background="#121212" Margin="1"/>
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ModernScrollBarThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0A0A0A" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#1A1A1A" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False">

                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Open Game File" Width="120" Command="{Binding OpenFileCommand}" Style="{StaticResource SecondaryButton}"/>
                        <Button Content="Save File" Width="90" Margin="10,0,0,0" Click="BtnSaveTranslation_Click" Background="#28A745" Foreground="White" BorderThickness="0" Visibility="{Binding IsTranslationFinished, Converter={StaticResource BooleanToVisibilityConverterFallback}}"/>
                        <Button Content="Report" Width="80" Margin="10,0,0,0" Click="BtnReport_Click" Background="#6C757D" Foreground="White" BorderThickness="0" Visibility="{Binding IsTranslationFinished, Converter={StaticResource BooleanToVisibilityConverterFallback}}"/>
                    </StackPanel>

                    <Button DockPanel.Dock="Right" Content="Settings" Width="80" Click="BtnSettings_Click" Style="{StaticResource SecondaryButton}" VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="From" VerticalAlignment="Center" Margin="20,0,8,0" Foreground="#888888" FontWeight="SemiBold"/>
                        <ComboBox Width="90" SelectedValue="{Binding SelectedSourceLanguage}" SelectedValuePath="Content">
                            <ComboBoxItem Content="English"/>
                            <ComboBoxItem Content="Russian"/>
                            <ComboBoxItem Content="Japanese"/>
                        </ComboBox>

                        <TextBlock Text="To" VerticalAlignment="Center" Margin="15,0,8,0" Foreground="#888888" FontWeight="SemiBold"/>
                        <ComboBox Width="90" SelectedValue="{Binding SelectedTargetLanguage}" SelectedValuePath="Content">
                            <ComboBoxItem Content="Arabic"/>
                            <ComboBoxItem Content="English"/>
                        </ComboBox>

                        <Grid Margin="15,0,0,0">
                            <Button Content="Translate All" Width="110" Command="{Binding StartTranslationCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTranslating}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="Cancel Translation" Width="125" Command="{Binding CancelTranslationCommand}" Background="#8B0000">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTranslating}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#A93226"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </StackPanel>
                </DockPanel>

                <Rectangle Grid.Row="1" Height="1" Fill="#1E1E1E" Margin="0,15,0,15"/>

                <DockPanel Grid.Row="2" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">

                        <Button Content="Find &amp; Replace" Command="{Binding OpenFindReplaceWindowCommand}" Width="120" Height="28" Background="#333333" Foreground="White" Cursor="Hand" BorderThickness="0" ToolTip="Search and replace text in translations">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Rectangle Width="1" Fill="#2A2A2A" Margin="15,4"/>

                        <TextBlock Text="Quick Clean:" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <TextBox Width="200" Text="{Binding TextToClean, UpdateSourceTrigger=PropertyChanged}" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" Padding="5,4" VerticalAlignment="Center" CaretBrush="White" Margin="0,0,8,0"/>
                        <Button Content="Remove Text" Command="{Binding CleanTranslatedTextCommand}" Width="90" Height="28" ToolTip="Remove the specified text from all translations">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#D84315"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#BF360C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Rectangle Width="1" Fill="#2A2A2A" Margin="15,4"/>

                        <Button Content="Clear All" Command="{Binding ClearAllTranslationsCommand}" Width="75" Height="28" ToolTip="Delete ALL translations completely">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#8B0000"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#A93226"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Search:" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <TextBox Width="220" Height="28" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" Padding="5,4" VerticalAlignment="Center" CaretBrush="White"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#0A0A0A" CornerRadius="5" Padding="10" Margin="0,0,0,10" BorderBrush="#1A1A1A" BorderThickness="1"
                Visibility="{Binding IsTranslating, Converter={StaticResource BooleanToVisibilityConverterFallback}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0" Height="10" Value="{Binding ProgressPercentage}" Minimum="0" Maximum="100" Background="#1E1E1E" Foreground="#0078D7" BorderThickness="0"/>
                <TextBlock Grid.Column="1" Text="{Binding EstimatedTimeRemaining}" Foreground="#888888" Margin="15,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" CornerRadius="8" BorderBrush="#1A1A1A" BorderThickness="1" ClipToBounds="True">
            <DataGrid AutoGenerateColumns="False" 
                      ItemsSource="{Binding TranslationItemsView}"
                      Background="#000000" AlternatingRowBackground="#050505"
                      HeadersVisibility="Column" GridLinesVisibility="None"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N" Binding="{Binding LineNumber}" Width="50" IsReadOnly="True" Foreground="#888888" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Group ID" Binding="{Binding ParentId}" Width="160" IsReadOnly="True" Foreground="#888888"/>
                    <DataGridTextColumn Header="String ID" Binding="{Binding Id}" Width="120" IsReadOnly="True" FontWeight="SemiBold"/>

                    <DataGridTextColumn Header="Original Text" Binding="{Binding OriginalText}" Width="3*" IsReadOnly="False">

                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>

                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="AcceptsReturn" Value="True"/>
                                <Setter Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="CaretBrush" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <ContextMenu.Style>
                                                <Style TargetType="ContextMenu">
                                                    <Setter Property="Background" Value="#1E1E1E"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ContextMenu">
                                                                <Border Background="{TemplateBinding Background}" BorderBrush="#333333" BorderThickness="1" CornerRadius="4" Padding="3">
                                                                    <ItemsPresenter />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ContextMenu.Style>

                                            <ContextMenu.Resources>
                                                <Style TargetType="MenuItem">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="MenuItem">
                                                                <Border x:Name="Border" Background="Transparent" CornerRadius="3" Padding="12,6,12,6" Margin="0,1">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <ContentPresenter Grid.Column="0" ContentSource="Header" VerticalAlignment="Center" Margin="0,0,30,0" TextElement.Foreground="White"/>
                                                                        <TextBlock Grid.Column="1" Text="{TemplateBinding InputGestureText}" Foreground="#888888" VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsHighlighted" Value="True">
                                                                        <Setter TargetName="Border" Property="Background" Value="#333333"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Foreground" Value="#555555"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ContextMenu.Resources>

                                            <MenuItem Command="ApplicationCommands.Cut" Header="Cut" />
                                            <MenuItem Command="ApplicationCommands.Copy" Header="Copy" />
                                            <MenuItem Command="ApplicationCommands.Paste" Header="Paste" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Translation" Binding="{Binding TranslatedText, UpdateSourceTrigger=PropertyChanged}" Width="4*" IsReadOnly="False">

                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TranslatedText}" Value="">
                                        <Setter Property="Foreground" Value="#666666"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>

                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="AcceptsReturn" Value="True"/>
                                <Setter Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="CaretBrush" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <ContextMenu.Style>
                                                <Style TargetType="ContextMenu">
                                                    <Setter Property="Background" Value="#1E1E1E"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ContextMenu">
                                                                <Border Background="{TemplateBinding Background}" BorderBrush="#333333" BorderThickness="1" CornerRadius="4" Padding="3">
                                                                    <ItemsPresenter />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ContextMenu.Style>

                                            <ContextMenu.Resources>
                                                <Style TargetType="MenuItem">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="MenuItem">
                                                                <Border x:Name="Border" Background="Transparent" CornerRadius="3" Padding="12,6,12,6" Margin="0,1">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <ContentPresenter Grid.Column="0" ContentSource="Header" VerticalAlignment="Center" Margin="0,0,30,0" TextElement.Foreground="White"/>
                                                                        <TextBlock Grid.Column="1" Text="{TemplateBinding InputGestureText}" Foreground="#888888" VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsHighlighted" Value="True">
                                                                        <Setter TargetName="Border" Property="Background" Value="#333333"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Foreground" Value="#555555"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ContextMenu.Resources>
                                            <MenuItem Command="ApplicationCommands.Cut" Header="Cut" />
                                            <MenuItem Command="ApplicationCommands.Copy" Header="Copy" />
                                            <MenuItem Command="ApplicationCommands.Paste" Header="Paste" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>