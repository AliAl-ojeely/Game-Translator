<Window x:Class="GameTranslator.SaveOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Options" Height="250" Width="450"
        Background="Transparent" AllowsTransparency="True" WindowStyle="None"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">


    <Border Background="#0A0A0A" CornerRadius="10" BorderBrush="#333333" BorderThickness="1" Margin="10">

        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="Black" Opacity="0.8"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <TextBlock Grid.Row="0" Text="Save Translation" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Grid.Row="1" Text="How would you like to save the translated file?" FontSize="14" Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,0,0,5"/>

            <StackPanel Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Stretch">
                <Button Content="Overwrite Original File" FontSize="14" Height="35" Margin="0,10,0,0" Background="#8B0000" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnOverwrite_Click" HorizontalAlignment="Stretch">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Save as New File" FontSize="14" Height="35" Margin="0,10,0,0" Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnSaveAs_Click" HorizontalAlignment="Stretch">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Cancel" FontSize="14" Height="35" Margin="0,10,0,0" Background="#333333" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click" HorizontalAlignment="Stretch">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>