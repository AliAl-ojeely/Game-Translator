<Window x:Class="GameTranslator.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Translation Report" Height="480" Width="450"
        Background="Transparent" AllowsTransparency="True" WindowStyle="None"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Border Background="#0A0A0A" CornerRadius="10" BorderBrush="#333333" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="Black" Opacity="0.8"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Translation Report" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock x:Name="TxtFileName" Foreground="#CCCCCC" Margin="0,2"/>
                <TextBlock x:Name="TxtTimeTaken" Foreground="#CCCCCC" Margin="0,2"/>
                <TextBlock x:Name="TxtTranslatedCount" Foreground="#CCCCCC" Margin="0,2"/>
                <TextBlock x:Name="TxtCharCount" Foreground="#CCCCCC" Margin="0,2"/>
                <TextBlock x:Name="TxtSkippedCount" Foreground="#E74C3C" Margin="0,2"/>
            </StackPanel>

            <GroupBox Grid.Row="2" Header="Skipped String IDs (Length > 2000)" Foreground="#888888" BorderBrush="#333333" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="ListSkippedIds" Grid.Column="0" Background="#121212" Foreground="#CCCCCC" BorderThickness="0" Margin="0,0,10,0"/>

                    <Button x:Name="BtnCopy" Grid.Column="1" Content="Copy Selected" Width="100" Height="30" VerticalAlignment="Top" Background="#1E1E1E" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnCopy_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </GroupBox>

            <Button Grid.Row="3" Content="Close" Height="35" Background="#333333" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>